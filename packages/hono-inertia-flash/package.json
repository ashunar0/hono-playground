{
  "name": "@ashunar0/hono-inertia-flash",
  "version": "0.0.1",
  "description": "Laravel/Rails-style shared data + flash session + redirect-back for @hono/inertia. Drop-in replacement of inertia() that adds c.share / c.flash / c.back.",
  "license": "MIT",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@hono/inertia": "^0.2.0",
    "hono": "^4.12.18",
    "typescript": "^5",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@hono/inertia": "^0.2.0",
    "hono": "^4.0.0"
  }
}
