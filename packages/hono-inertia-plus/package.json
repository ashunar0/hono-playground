{
  "name": "@ashunar0/hono-inertia-plus",
  "version": "0.0.1",
  "description": "Protocol superset of @hono/inertia: shared data (c.share), partial reloads, deferred props, merge props, and Inertia v3 infinite scroll — in a single render-time middleware.",
  "license": "MIT",
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@hono/inertia": "^0.2.0",
    "hono": "^4.12.18",
    "typescript": "^5",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@hono/inertia": "^0.2.0",
    "hono": "^4.0.0"
  }
}
